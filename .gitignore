backend/venv/
backend/env/

# 環境変数・機密情報（世界に漏らしてはいけないパスワードなど）
.env
*.env
backend/.env
frontend/.env

# OSが勝手に作るゴミファイル
.DS_Store
Thumbs.db

# その他
*.code-workspace
.vscode/